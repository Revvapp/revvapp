// Revv — Cloud Storage security rules.
// Deployed via the CLI: firebase deploy --only storage
// (wired through firebase.json). Firestore rules live in ../firestore.rules.

rules_version = '2';

service firebase.storage {
  match /b/{bucket}/o {

    match /detailers/{uid}/{allPaths=**} {
      allow read: if true;
      allow write: if request.auth != null && request.auth.uid == uid;
    }

    match /vir-photos/{bookingId}/{allPaths=**} {
      allow read: if request.auth != null;
      allow write: if request.auth != null;
    }

    match /after-photos/{bookingId}/{allPaths=**} {
      allow read: if request.auth != null;
      allow write: if request.auth != null;
    }

    match /disputes/{uid}/{allPaths=**} {
      allow read: if request.auth != null;
      allow write: if request.auth != null && request.auth.uid == uid;
    }

  }
}
